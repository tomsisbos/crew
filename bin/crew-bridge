#!/usr/bin/env bash
#
# crew-bridge — surface herdr agent-state transitions into the agmsg message stream.
#
# For each crew-managed agent (recorded by `crew new` / `crew watch` under the state dir),
# it polls herdr for the pane's agent_status. On a *meaningful* transition (default: ->
# blocked, -> done) it sends a short message to every other crew agent on the same team, so
# a teammate going blocked ("needs input") or done ("turn finished, free now") proactively
# reaches the others without anyone polling.
#
# Echo-suppression: in monitor mode a delivered note wakes the recipient, who takes a turn
# and so flips working -> done — which would be re-announced, waking everyone again, forever.
# To break that, we remember when we last *pinged* each agent; if it transitions into an
# announce state within BRIDGE_ECHO_WINDOW seconds of that ping, we treat it as the echo of
# our own message and stay quiet. `blocked` is exempt (a ping never *causes* blocked, and the
# reaction to a blocked note is a done — which is suppressed — so it can't sustain a loop).
#
# This is intentionally a poll loop (pure bash + jq): herdr's pane.agent_status_changed
# socket subscription needs a pane_id per pane, so a poll over `herdr pane list` is the
# simpler, more robust v1. See README "Roadmap" for the event-driven upgrade.
#
# Run via `crew bridge`; `crew new` also starts one in the background (pidfile under
# the state dir keeps it a singleton).

set -euo pipefail

CREW_CONF="${CREW_CONF:-${XDG_CONFIG_HOME:-$HOME/.config}/crew/crew.conf}"
TEAM="crew"
AGMSG_CMD="agmsg"
BRIDGE_TRANSITIONS="blocked done"
BRIDGE_INTERVAL="3"
BRIDGE_ECHO_WINDOW="60"
# shellcheck source=/dev/null
[ -f "$CREW_CONF" ] && . "$CREW_CONF"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/crew"
AGMSG_SCRIPTS="$HOME/.agents/skills/$AGMSG_CMD/scripts"
SEND="$AGMSG_SCRIPTS/send.sh"
# Per-agent "<name>.lastping" files record the epoch we last sent that agent a note (used
# for echo-suppression). File-based to stay bash-3.2 compatible (no associative arrays).

# Human-readable hint per state.
hint() {
  case "$1" in
    blocked) echo "needs input";;
    done)    echo "finished / awaiting next";;
    idle)    echo "idle / free";;
    working) echo "working";;
    *)       echo "$1";;
  esac
}

# Is <status> one of the configured transitions we announce?
announces() {
  local s="$1" t
  for t in $BRIDGE_TRANSITIONS; do [ "$s" = "$t" ] && return 0; done
  return 1
}

log() { printf '%s crew-bridge: %s\n' "$(date '+%H:%M:%S')" "$*"; }

log "watching (team filter via registry; transitions: '$BRIDGE_TRANSITIONS'; interval ${BRIDGE_INTERVAL}s)"

while :; do
  NOW="$(date +%s)"
  snapshot="$(herdr pane list 2>/dev/null || true)"
  if [ -n "$snapshot" ]; then
    # iterate every registered crew agent
    for desc in "$STATE_DIR"/agents/*/*.json; do
      [ -f "$desc" ] || continue
      name="$(jq -r '.name' "$desc")"
      team="$(jq -r '.team' "$desc")"
      pane="$(jq -r '.pane_id' "$desc")"
      laststatus_file="${desc%.json}.laststatus"

      status="$(printf '%s' "$snapshot" \
        | jq -r --arg p "$pane" '.result.panes[]? | select(.pane_id==$p) | .agent_status')"
      # pane gone (worktree retired) — leave the registry alone, just skip.
      [ -n "$status" ] || continue

      last="unknown"; [ -f "$laststatus_file" ] && last="$(cat "$laststatus_file")"
      [ "$status" = "$last" ] && continue

      printf '%s' "$status" >"$laststatus_file"
      log "$team/$name: $last -> $status"
      announces "$status" || continue

      # echo-suppression: if this agent transitioned right after we pinged it, it's just
      # reacting to our note (working -> done) — announcing it would wake everyone again in
      # an endless loop. Stay quiet. 'blocked' is exempt: a ping never causes it, and the
      # reaction to a blocked note is a done (suppressed), so it can't sustain a loop.
      if [ "$status" != "blocked" ]; then
        lastping_file="${desc%.json}.lastping"
        lastping=0; [ -f "$lastping_file" ] && lastping="$(cat "$lastping_file")"
        if [ "$((NOW - lastping))" -le "$BRIDGE_ECHO_WINDOW" ]; then
          log "$team/$name: $status suppressed (echo of a bridge ping $((NOW - lastping))s ago)"
          continue
        fi
      fi

      # fan out to the other crew members on the same team
      for other_desc in "$STATE_DIR/agents/$team"/*.json; do
        [ -f "$other_desc" ] || continue
        other="$(jq -r '.name' "$other_desc")"
        [ "$other" = "$name" ] && continue
        "$SEND" "$team" crew-bridge "$other" "$name → $status ($(hint "$status"))" >/dev/null 2>&1 || true
        # remember we pinged this teammate, so its imminent working->done echo stays quiet.
        printf '%s' "$NOW" >"${other_desc%.json}.lastping"
      done
    done
  fi
  sleep "$BRIDGE_INTERVAL"
done
